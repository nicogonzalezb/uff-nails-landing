---
const pasos = [
  {
    numero: "01",
    titulo: "Elige tu manicurista",
    descripcion: "Selecciona a la especialista que más te gusta según su estilo y disponibilidad.",
    emoji: "👆",
  },
  {
    numero: "02",
    titulo: "Coordina por WhatsApp",
    descripcion: "Cuéntanos qué servicio quieres, el día y la dirección. Te confirmaremos en minutos.",
    emoji: "💬",
  },
  {
    numero: "03",
    titulo: "Paga y disfruta",
    descripcion: "Paga por transferencia al confirmar. Tu manicurista llega a tu puerta lista para trabajar.",
    emoji: "✅",
  },
];
---

<section id="como-funciona" class="py-20 bg-white">
  <div class="max-w-5xl mx-auto px-6">
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">Cómo funciona</h2>
      <p class="text-gray-500 text-lg">Reserva en 3 pasos simples, sin apps ni cuentas.</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
      {pasos.map((p, i) => (
        <div class="flex flex-col items-center text-center">
          <div class="relative mb-6">
            <div class="w-20 h-20 rounded-full bg-pink-soft flex items-center justify-center text-4xl shadow-md">
              {p.emoji}
            </div>
            <span class="absolute -top-2 -right-2 w-7 h-7 rounded-full bg-pink-primary text-white text-xs font-bold flex items-center justify-center">
              {p.numero.slice(1)}
            </span>
          </div>
          <h3 class="font-bold text-gray-900 text-xl mb-2">{p.titulo}</h3>
          <p class="text-gray-500">{p.descripcion}</p>
          {i < pasos.length - 1 && (
            <div class="hidden md:block absolute" />
          )}
        </div>
      ))}
    </div>

    <div class="mt-14 text-center">
      <a
        href="#manicuristas"
        class="inline-block bg-pink-primary text-white font-bold px-10 py-4 rounded-full text-lg hover:bg-opacity-90 transition shadow-lg shadow-pink-light"
      >
        Reservar ahora →
      </a>
    </div>
  </div>
</section>
