---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import Manicuristas from '../components/Manicuristas.astro';
import Servicios from '../components/Servicios.astro';
import ComoFunciona from '../components/ComoFunciona.astro';
import Testimonios from '../components/Testimonios.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Manicure profesional a domicilio en Bogotá. Escoge tu manicurista y reserva en segundos." />
    <title>Uff Nails — Manicure a Domicilio en Bogotá</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&display=swap" rel="stylesheet" />
    <style>
      [x-cloak] { display: none !important; }
    </style>
  </head>
  <body class="font-sans antialiased text-gray-900 bg-white">
    <nav class="sticky top-0 z-50 bg-white/90 backdrop-blur border-b border-pink-light">
      <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
        <span class="font-bold text-xl text-pink-primary">Uff Nails</span>
        <div class="hidden md:flex items-center gap-8 text-sm font-medium text-gray-600">
          <a href="#manicuristas" class="hover:text-pink-primary transition">Manicuristas</a>
          <a href="#servicios" class="hover:text-pink-primary transition">Servicios</a>
          <a href="#como-funciona" class="hover:text-pink-primary transition">Cómo funciona</a>
        </div>
        <a
          href="#manicuristas"
          class="bg-pink-primary text-white font-semibold px-5 py-2.5 rounded-full text-sm hover:bg-opacity-90 transition"
        >
          Reservar
        </a>
      </div>
    </nav>

    <main>
      <Hero />
      <Manicuristas />
      <Servicios />
      <ComoFunciona />
      <Testimonios />
    </main>

    <Footer />
    <!-- Alpine debe cargar después del módulo que registra alpine:init (script de Manicuristas.astro). -->
    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </body>
</html>
